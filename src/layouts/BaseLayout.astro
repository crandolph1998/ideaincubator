---
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Idea Incubator — Content Marketing & SEO Services',
  description = 'Content writing, link building, digital PR, and managed SEO services without long-term contracts.'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="grid-bg">
    <div class="bg-accent py-3 text-center text-sm font-medium text-foreground">
      Ready to make content marketing work for you? Book a call today.
    </div>
    <header class="sticky top-0 z-30 border-b border-border bg-background/95 backdrop-blur">
      <div class="container flex items-center justify-between py-4">
        <a href="/" class="text-lg font-semibold tracking-tight">Idea Incubator</a>
        <nav class="hidden items-center gap-8 text-sm md:flex">
          <a href="#services" class="text-muted transition hover:text-foreground">Services</a>
          <a href="#testimonials" class="text-muted transition hover:text-foreground">Testimonials</a>
          <a href="#contact" class="text-muted transition hover:text-foreground">Contact</a>
          <a href="#contact" class="rounded-full border border-border bg-white px-4 py-2 text-foreground transition hover:border-primary hover:text-primary">Book A Free Call</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="mt-20 border-t border-border bg-white py-12">
      <div class="container space-y-8">
        <p class="text-xl font-semibold">Idea Incubator</p>
        <div class="grid gap-8 text-sm text-muted md:grid-cols-3">
          <div>
            <p class="font-semibold text-foreground">Company</p>
          </div>
          <div>
            <p class="font-semibold text-foreground">Useful Links</p>
          </div>
          <div>
            <p class="font-semibold text-foreground">Contact</p>
          </div>
        </div>
        <p class="text-sm text-muted">Copyright © 2026 — Idea Incubator, LLC</p>
      </div>
    </footer>
  </body>
</html>
