---
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Idea Incubator — Content Marketing & SEO Services',
  description = 'We write content your audience, search engines, and AI answer engines love.'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="bg-notice py-2 text-center text-sm text-foreground">Ready to make content marketing work for you? Book a call today.</div>
    <header class="sticky top-0 z-30 border-b border-border bg-background/95">
      <div class="container flex items-center justify-between py-4">
        <a href="/" class="text-lg font-semibold tracking-tight">Idea Incubator</a>
        <nav class="hidden items-center gap-8 text-sm md:flex">
          <a href="#services" class="hover:text-primary">Services</a>
          <a href="#testimonials" class="hover:text-primary">Testimonials</a>
          <a href="#contact" class="hover:text-primary">Contact</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="mt-16 border-t border-border py-12">
      <div class="container grid gap-8 text-sm text-foreground/80 md:grid-cols-3">
        <div>
          <h3 class="font-semibold text-foreground">Company</h3>
          <p class="mt-3">Idea Incubator</p>
        </div>
        <div>
          <h3 class="font-semibold text-foreground">Useful Links</h3>
          <ul class="mt-3 space-y-2">
            <li><a href="#services" class="hover:text-primary">Services</a></li>
            <li><a href="#contact" class="hover:text-primary">Book a Call</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-foreground">Contact</h3>
          <p class="mt-3">hello@ideaincubator.co</p>
        </div>
      </div>
    </footer>
  </body>
</html>
