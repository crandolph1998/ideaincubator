---
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Idea Incubator — Content Marketing & SEO Services',
  description = 'We write content your audience, search engines, and AI answer engines love.'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="bg-notice py-2 text-center text-sm text-foreground">Ready to make content marketing work for you? Book a call today.</div>
    <div id="header-sentinel" aria-hidden="true"></div>
    <header id="site-header" class="site-header">
      <div class="container flex items-center justify-between py-4">
        <a href="/" class="text-lg font-semibold tracking-tight">Idea Incubator</a>
        <nav class="hidden items-center gap-8 text-sm md:flex">
          <a href="#services" class="transition hover:text-primary">Services</a>
          <a href="#testimonials" class="transition hover:text-primary">Testimonials</a>
          <a href="#contact" class="transition hover:text-primary">Contact</a>
        </nav>
      </div>
    </header>
    <main class="pt-2">
      <slot />
    </main>
    <footer class="mt-16 border-t border-border py-12">
      <div class="container grid gap-8 text-sm text-muted md:grid-cols-4">
        <div>
          <h3 class="text-base font-semibold text-foreground">Idea Incubator</h3>
          <p class="mt-2">Logo</p>
        </div>
        <div>
          <h3 class="font-semibold text-foreground">Company</h3>
          <p class="mt-3">Idea Incubator, LLC</p>
        </div>
        <div>
          <h3 class="font-semibold text-foreground">Useful Links</h3>
          <ul class="mt-3 space-y-2">
            <li><a href="#services" class="hover:text-primary">Services</a></li>
            <li><a href="#contact" class="hover:text-primary">Book a Call</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-foreground">Contact</h3>
          <p class="mt-3">hello@ideaincubator.co</p>
        </div>
      </div>
      <p class="container mt-10 border-t border-border pt-6 text-sm text-muted">Copyright © 2026 — Idea Incubator, LLC</p>
    </footer>
    <script>
      const header = document.getElementById('site-header');
      const sentinel = document.getElementById('header-sentinel');

      if (header && sentinel) {
        const observer = new IntersectionObserver(
          ([entry]) => {
            header.classList.toggle('is-stuck', !entry.isIntersecting);
          },
          { rootMargin: '-4px 0px 0px 0px', threshold: 1 }
        );

        observer.observe(sentinel);
      }
    </script>
  </body>
</html>
