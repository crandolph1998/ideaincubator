---
interface Props {
  href?: string;
  variant?: 'default' | 'outline';
}

const { href, variant = 'default' } = Astro.props;
const base = 'inline-flex items-center justify-center rounded-lg px-6 py-3 text-sm font-semibold transition duration-200';
const classes =
  variant === 'outline'
    ? `${base} border border-accent text-foreground hover:bg-white hover:shadow-soft`
    : `${base} bg-primary text-white shadow-soft hover:-translate-y-0.5 hover:opacity-95`;
---

{href ? <a href={href} class={classes}><slot /></a> : <button class={classes}><slot /></button>}
