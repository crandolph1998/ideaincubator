---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';

const logos = ['Proxycurl', 'The Happier Hustle', 'Email Engineers', 'Woop Insurance', 'Sqribble', 'MyServiceArea', 'Sapiengraph', 'KE'];

const services = [
  {
    title: 'Content Writing',
    features: [
      'Research-driven blog posts and articles',
      'Product descriptions that convert',
      'Website copy and landing pages',
      'Industry-specific content strategies',
      'AI-optimized formatting for search visibility'
    ],
    text: 'SEO-optimized blog posts, articles, and web copy that engages your audience, drives organic traffic, and converts.'
  },
  {
    title: 'Link Building',
    features: [
      'High-quality niche edits and link insertions',
      'Guest posting on relevant industry sites',
      'Contextual link excerpts in existing content',
      'Authority site partnerships',
      'White-hat link acquisition strategies'
    ],
    text: 'Strategic link placement services that boost your domain authority and search rankings.'
  },
  {
    title: 'Digital PR',
    features: [
      'Professional press release writing and distribution',
      'Media outreach to industry publications',
      'Brand mention campaigns',
      'Newsworthy content development',
      'PR-driven link building opportunities'
    ],
    text: 'Press release distribution and PR campaigns that build brand authority and earn quality backlinks.'
  },
  {
    title: 'Full-Service Managed SEO',
    features: [
      'Complete SEO strategy development',
      'Content creation and link building integration',
      'Technical SEO audits and implementation',
      'Performance tracking and reporting',
      'Custom campaigns tailored to your industry'
    ],
    text: 'Comprehensive SEO management combining content, links, and technical optimization for maximum results.'
  }
];
---

<BaseLayout>
  <section class="container py-20 md:py-24">
    <div class="mx-auto flex max-w-4xl flex-col items-center space-y-8 text-center">
      <h1 class="text-balance text-4xl font-bold tracking-tight md:text-6xl">We Write Content That Your Target Audience, Search Engines, and AI Answer Engines Love</h1>
      <div class="space-y-5 text-lg text-muted">
        <p>While other content marketing and SEO agencies deliver cookie-cutter fluff that not a single person would want to read, we deliver well-researched, informative, and engaging content that truly delivers on search intent. We can also take care of everything else you need to grow your brand awareness and authority, such as backlinks, press releases, and more.</p>
        <p>The best part? Zero contracts. You buy the exact deliverables you need at an affordable rate, as you need them. Or, we can manage it all for you, and we'll tell you what you need. Your choice.</p>
      </div>
      <div class="flex flex-wrap justify-center gap-4">
        <Button href="#services">Get Started</Button>
        <Button href="#contact" variant="outline">Book A Free Call</Button>
      </div>
    </div>
  </section>

  <section class="container py-10">
    <h2 class="text-center text-sm font-semibold uppercase tracking-[.2em] text-muted">Trusted by Many</h2>
    <div class="mx-auto mt-5 grid max-w-5xl grid-cols-2 gap-3 md:grid-cols-4">
      {logos.map((logo) => <div class="rounded-md border border-border bg-card px-4 py-3 text-center text-sm font-medium">{logo}</div>)}
    </div>
  </section>

  <section id="services" class="container py-16">
    <h2 class="text-center text-3xl font-bold tracking-tight md:text-4xl">Explore Our SEO Services</h2>
    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {services.map((service) => (
        <Card>
          <h3 class="text-2xl font-semibold">{service.title}</h3>
          <p class="mt-3 text-muted">{service.text}</p>
          <ul class="mt-4 space-y-2 text-sm text-muted">
            {service.features.map((feature) => <li>• {feature}</li>)}
          </ul>
        </Card>
      ))}
    </div>
  </section>

  <section id="testimonials" class="container py-16">
    <h2 class="text-center text-3xl font-bold tracking-tight md:text-4xl">What clients have to say</h2>
    <div class="mx-auto mt-8 max-w-3xl">
      <Card>
        <blockquote class="text-center text-lg text-muted">“I have been working with these guys for years now! With lots of hard work and timely communication, they made sure they delivered the best to me. Highly recommended!”</blockquote>
        <p class="mt-5 text-center font-semibold">— John Doe</p>
        <p class="text-center text-sm text-muted">Company Name</p>
      </Card>
    </div>
  </section>

  <section id="contact" class="container pb-16 pt-8">
    <div class="mx-auto max-w-4xl">
      <Card>
        <h2 class="text-center text-3xl font-bold tracking-tight md:text-4xl">Ready to Get More Customers Through Content?</h2>
        <p class="mx-auto mt-4 max-w-3xl text-center text-muted">Let’s create a content marketing system that consistently attracts qualified leads and turns your expertise into revenue. Book a free strategy call to see how we can help.</p>
        <div class="mt-6 flex justify-center">
          <Button href="mailto:hello@ideaincubator.co">Book Your Free Strategy Call</Button>
        </div>
      </Card>
    </div>
  </section>
</BaseLayout>
