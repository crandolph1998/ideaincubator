---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';

const logos = ['Proxycurl', 'The Happier Hustle', 'Email Engineers', 'Woop Insurance', 'Sqribble', 'MyServiceArea', 'Sapiengraph', 'KE'];

const services = [
  {
    title: 'Content Writing',
    description: 'SEO-optimized blog posts, articles, and web copy that engages your audience, drives organic traffic, and converts.',
    items: [
      'Research-driven blog posts and articles',
      'Product descriptions that convert',
      'Website copy and landing pages',
      'Industry-specific content strategies',
      'AI-optimized formatting for search visibility'
    ]
  },
  {
    title: 'Link Building',
    description: 'Strategic link placement services that boost your domain authority and search rankings.',
    items: [
      'High-quality niche edits and link insertions',
      'Guest posting on relevant industry sites',
      'Contextual link excerpts in existing content',
      'Authority site partnerships',
      'White-hat link acquisition strategies'
    ]
  },
  {
    title: 'Digital PR',
    description: 'Press release distribution and PR campaigns that build brand authority and earn quality backlinks.',
    items: [
      'Professional press release writing and distribution',
      'Media outreach to industry publications',
      'Brand mention campaigns',
      'Newsworthy content development',
      'PR-driven link building opportunities'
    ]
  },
  {
    title: 'Full-Service Managed SEO',
    description: 'Comprehensive SEO management combining content, links, and technical optimization for maximum results.',
    items: [
      'Complete SEO strategy development',
      'Content creation and link building integration',
      'Technical SEO audits and implementation',
      'Performance tracking and reporting',
      'Custom campaigns tailored to your industry'
    ]
  }
];
---

<BaseLayout title="Idea Incubator | Content Marketing & SEO" description="We write content your audience, search engines, and AI answer engines love.">
  <section class="container py-20 md:py-24">
    <div class="space-y-8">
      <div class="space-y-5">
        <h1 class="max-w-5xl text-balance text-4xl font-semibold tracking-tight md:text-6xl">
          We Write Content That Your Target Audience, Search Engines, and AI Answer Engines Love
        </h1>
        <p class="max-w-4xl text-lg text-muted">
          While other content marketing and SEO agencies deliver cookie-cutter fluff that not a single person would want to read, we deliver
          well-researched, informative, and engaging content that truly delivers on search intent. We can also take care of everything else you need
          to grow your brand awareness and authority, such as backlinks, press releases, and more.
        </p>
        <p class="max-w-4xl text-lg text-muted">
          The best part? Zero contracts. You buy the exact deliverables you need at an affordable rate, as you need them. Or, we can manage it all
          for you, and we'll tell you what you need. Your choice.
        </p>
      </div>
      <div class="flex flex-wrap gap-4">
        <Button href="#services">Get Started</Button>
        <Button href="#contact" variant="outline">Book A Free Call</Button>
      </div>
    </div>
  </section>

  <section class="container py-10">
    <SectionHeading eyebrow="Trusted by Many" title="Trusted by Many" />
    <div class="mt-8 grid gap-3 sm:grid-cols-2 md:grid-cols-4">
      {logos.map((logo) => (
        <div class="rounded-xl border border-border bg-white px-4 py-4 text-center text-sm font-medium text-muted">{logo}</div>
      ))}
    </div>
  </section>

  <section id="services" class="container py-16">
    <SectionHeading eyebrow="Services" title="Explore Our SEO Services" />
    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {services.map((service) => (
        <Card>
          <h3 class="text-2xl font-semibold">{service.title}</h3>
          <p class="mt-3 text-muted">{service.description}</p>
          <ul class="mt-4 space-y-2 text-muted">
            {service.items.map((item) => (
              <li>• {item}</li>
            ))}
          </ul>
        </Card>
      ))}
    </div>
  </section>

  <section id="testimonials" class="container py-16">
    <SectionHeading eyebrow="Testimonials" title="What clients have to say" />
    <div class="mt-8">
      <Card>
        <p class="text-lg text-foreground/90">
          “I have been working with these guys for years now! With lots of hard work and timely communication, they made sure they delivered the best
          to me. Highly recommended!”
        </p>
        <p class="mt-5 font-semibold">— John Doe</p>
        <p class="text-sm text-muted">Company Name</p>
      </Card>
    </div>
  </section>

  <section id="contact" class="container py-16">
    <Card>
      <SectionHeading
        eyebrow="Final CTA"
        title="Ready to Get More Customers Through Content?"
        description="Let’s create a content marketing system that consistently attracts qualified leads and turns your expertise into revenue. Book a free strategy call to see how we can help."
      />
      <div class="mt-8">
        <Button href="#">Book Your Free Strategy Call</Button>
      </div>
    </Card>
  </section>
</BaseLayout>
